# Backend API URL (Production)
VITE_API_BASE_URL=https://api.rezervitoo.com/api/v1

# WebSocket URL for real-time notifications (Production)
VITE_WS_BASE_URL=wss://api.rezervitoo.com

# Google OAuth Client ID
# Get from: https://console.cloud.google.com/ → APIs & Services → Credentials
# Add http://localhost:5173 (dev) and your Netlify domain (prod) to Authorized JavaScript origins
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
